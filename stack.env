# Portainer stack environment — replace placeholders before deploy.
# In Portainer: Stack → Environment variables → load this file, or edit values in the UI.

# Plaid — https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_secret
PLAID_ENV=sandbox
PLAID_DAYS_REQUESTED=90
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=

# External MongoDB (required)
MONGODB_URI=mongodb://user:pass@your-host:27017/?authSource=admin
MONGODB_DATABASE=mmm

# Service — use 0.0.0.0 inside the container
HOST=0.0.0.0
PORT=47829
SYNC_INTERVAL_SECONDS=300
SYNC_ON_STARTUP=true
