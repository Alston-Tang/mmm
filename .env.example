# Plaid — https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_secret
PLAID_ENV=sandbox

# Max transaction history days when linking (max 730)
PLAID_DAYS_REQUESTED=90

# OAuth / webhooks (production)
# PLAID_REDIRECT_URI=https://your-domain/api/v1/link
# PLAID_WEBHOOK_URL=https://your-domain/api/v1/webhooks/plaid

# External MongoDB (required — not bundled in docker-compose)
MONGODB_URI=mongodb://user:pass@your-host:27017/?authSource=admin
MONGODB_DATABASE=mmm

# Service (Plaid sync)
HOST=0.0.0.0
PORT=47829
SYNC_INTERVAL_SECONDS=300
SYNC_ON_STARTUP=true

# Transaction analysis service (python -m analysis.main)
ANALYSIS_PORT=47830
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=16384
ANALYSIS_INTERVAL_SECONDS=300
ANALYSIS_ON_STARTUP=true
ANALYSIS_BATCH_SIZE=30
ANALYSIS_WINDOW_DAYS=90
CONFIDENCE_THRESHOLD=0.75

# Web search (optional — enriches uncertain transactions before LLM retry)
SEARCH_ENABLED=true
SEARCH_API_KEY=your_tavily_or_serper_api_key
SEARCH_PROVIDER=tavily
SEARCH_MAX_RESULTS=3
SEARCH_MAX_QUERIES=5
SEARCH_MAX_CONCURRENT=3
SEARCH_TIMEOUT_SECONDS=15

# WeChat Pay bill context (optional — enriches likely WeChat credit-card charges)
WECHAT_ENABLED=true
WECHAT_DATE_WINDOW_DAYS=3
WECHAT_AMOUNT_TOLERANCE_RATIO=0.15
WECHAT_USD_CNY_RATE=7.2
WECHAT_MAX_CANDIDATES=15

# Transaction viewer service (python -m viewer.main)
VIEWER_PORT=47831
